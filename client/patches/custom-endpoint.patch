+// ================= CUSTOM: genuine TLS to relay endpoint (SNI the configured host) =================
+void ConnectionSocket::realTlsInit() {
+    static SSL_CTX *ctx = nullptr;
+    if (ctx == nullptr) {
+        ctx = SSL_CTX_new(TLS_client_method());
+        SSL_CTX_set_min_proto_version(ctx, TLS1_2_VERSION);
+        SSL_CTX_set_verify(ctx, SSL_VERIFY_NONE, nullptr);   // relay cert not validated; MTProto stays E2E to the DC
+    }
+    SSL *ssl = SSL_new(ctx);
+    BIO *rb = BIO_new(BIO_s_mem());
+    BIO *wb = BIO_new(BIO_s_mem());
+    SSL_set_bio(ssl, rb, wb);
+    const std::string &sni = ConnectionsManager::relaySni;
+    SSL_set_tlsext_host_name(ssl, sni.empty() ? "www.microsoft.com" : sni.c_str());
+    SSL_set_connect_state(ssl);
+    sslHandle = ssl;
+    sslRbio = rb;
+    sslWbio = wb;
+    realTlsConnected = false;
+}
+
+void ConnectionSocket::realTlsFree() {
+    if (sslHandle != nullptr) {
+        SSL_free((SSL *) sslHandle);   // also frees the attached BIOs
+        sslHandle = nullptr;
+        sslRbio = nullptr;
+        sslWbio = nullptr;
+    }
+    realTlsConnected = false;
+}
+
+void ConnectionSocket::realTlsFlushOut() {
+    if (sslWbio == nullptr) return;
+    char buf[16384];
+    int n;
+    while ((n = BIO_read((BIO *) sslWbio, buf, sizeof(buf))) > 0) {
+        int off = 0;
+        while (off < n) {
+            ssize_t s = send(socketFd, buf + off, (size_t) (n - off), 0);
+            if (s <= 0) return;
+            off += (int) s;
+        }
+    }
+}
+
+bool ConnectionSocket::realTlsHandshakeStep() {
+    SSL *ssl = (SSL *) sslHandle;
+    if (ssl == nullptr) return false;
+    int r = SSL_do_handshake(ssl);
+    realTlsFlushOut();
+    if (r == 1) {
+        realTlsConnected = true;
+        if (LOGS_ENABLED) DEBUG_D("connection(%p) real TLS handshake complete, relay dc=%d", this, (int) relayDcId);
+        uint8_t routeHdr[5] = { 'T', 'G', 'R', '1', relayDcId };   // CUSTOM: DC-routing header for our relay
+        SSL_write((SSL *) sslHandle, routeHdr, 5);
+        realTlsFlushOut();
+        if (!onConnectedSent) {
+            lastEventTime = ConnectionsManager::getInstance(instanceNum).getCurrentTimeMonotonicMillis();
+            onConnected();
+            onConnectedSent = true;
+        }
+        adjustWriteOp();
+        return true;
+    }
+    int err = SSL_get_error(ssl, r);
+    if (err == SSL_ERROR_WANT_READ || err == SSL_ERROR_WANT_WRITE) {
+        adjustWriteOp();
+        return false;
+    }
+    if (LOGS_ENABLED) DEBUG_E("connection(%p) real TLS handshake fatal error %d", this, err);
+    closeSocket(1, -1);
+    return false;
+}
+
+void ConnectionSocket::realTlsOnReadable(uint8_t *data, int len) {
+    if (sslHandle == nullptr) realTlsInit();
+    BIO_write((BIO *) sslRbio, data, len);   // ciphertext consumed into rbio (data may now be overwritten)
+    if (!realTlsConnected) {
+        if (!realTlsHandshakeStep()) return;
+    }
+    NativeByteBuffer *nb = ConnectionsManager::getInstance(instanceNum).networkBuffer;
+    while (true) {
+        SSL *ssl = (SSL *) sslHandle;   // CUSTOM: re-read each iter; onReceivedData() may closeSocket()->realTlsFree()
+        if (ssl == nullptr) break;      // CUSTOM: SSL freed underneath us -> stop (fixes use-after-free SIGSEGV)
+        nb->rewind();
+        int n = SSL_read(ssl, nb->bytes(), READ_BUFFER_SIZE);
+        if (n <= 0) break;
+        nb->limit((uint32_t) n);
+        onReceivedData(nb);
+    }
+}
+
+void ConnectionSocket::realTlsWrite(uint8_t *data, uint32_t len) {
+    if (sslHandle == nullptr) return;
+    SSL_write((SSL *) sslHandle, data, (int) len);
+    realTlsFlushOut();
+}
